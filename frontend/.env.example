# AxonSwap Frontend — Environment Variables
# Copy this file to .env.local and fill in the deployed contract addresses.
# All variables must be prefixed with NEXT_PUBLIC_ to be accessible in the browser.

# ─── Contract Addresses (fill in after deploying with contracts/scripts/deploy.js) ───
NEXT_PUBLIC_WAXON_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_SWAP_ROUTER_ADDRESS=
NEXT_PUBLIC_POSITION_MANAGER_ADDRESS=
NEXT_PUBLIC_QUOTER_ADDRESS=
NEXT_PUBLIC_QUOTER_V2_ADDRESS=
NEXT_PUBLIC_TICK_LENS_ADDRESS=
NEXT_PUBLIC_MULTICALL_ADDRESS=

# ─── Token Addresses (fill in with actual ERC-20 addresses on Axonchain) ───
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_USDT_ADDRESS=
NEXT_PUBLIC_WBTC_ADDRESS=
NEXT_PUBLIC_WETH_ADDRESS=

# ─── WalletConnect / Reown Project ID (optional, for WalletConnect support) ───
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
